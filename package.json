{
  "name": "local-dev-manager",
  "version": "1.2.0",
  "description": "A desktop app to manage and launch your local dev projects",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-rebuild -f -w node-pty && electron-builder --mac",
    "build:all": "electron-rebuild -f -w node-pty && electron-builder --mac --win --linux"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.local-dev-manager",
    "productName": "Local Dev Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "xterm-loader.js",
      "index.html",
      "styles.css",
      "package.json",
      "src/**",
      "node_modules/@xterm/**",
      "node_modules/node-pty/**"
    ],
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
